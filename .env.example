# ============================================================================
# KronoPool — variables d'environnement (exemple)
# Copier vers .env et remplir. NE JAMAIS commiter .env ni mettre de vraies
# valeurs dans ce fichier d'exemple. Détail : README.md § Variables d'environnement.
# ============================================================================

# Port hôte publié par docker compose (le Cloudflare Tunnel pointe dessus).
# Le port interne du conteneur reste 3000. Défaut : 3000.
APP_PORT=3000

# URL publique EXACTE de l'app (schéma + domaine, sans slash final). Indispensable
# derrière le Cloudflare Tunnel : SvelteKit (adapter-node) l'utilise pour valider
# l'origine des formulaires (CSRF). Une valeur incorrecte => erreur 403
# « Cross-site POST form submissions are forbidden » à la connexion.
ORIGIN=https://app.example.com

# Base de données (libSQL). Local : fichier. Futur : URL Turso + AUTH_TOKEN.
DATABASE_URL=file:./data/app.db
# DATABASE_AUTH_TOKEN=            # requis uniquement pour Turso (URL distante)

# Dossier de stockage des documents des intervenants (volume persistant).
# Optionnel : par défaut dérivé de DATABASE_URL (./data/documents en local,
# /data/documents en conteneur). À définir seulement pour un emplacement custom.
# DOCUMENTS_DIR=/data/documents

# ⚠️ NON UTILISÉE à ce jour : les tokens de session sont aléatoires et stockés
# hashés, pas signés — aucun code ne lit cette variable (voir docs/AUDIT.md m15).
# Conservée pour d'éventuelles évolutions (signature de cookies, etc.).
SESSION_SECRET=change-me-in-production

# Comptes admin initiaux créés par le seed (npm run db:seed, ou au boot Docker).
# Seed idempotent : changer le mot de passe ici NE modifie PAS un compte déjà créé.
ADMIN1_EMAIL=directeur@piscine.fr
ADMIN1_PASSWORD=change-me-admin-1
ADMIN1_NOM=Directeur
ADMIN1_PRENOM=Principal

ADMIN2_EMAIL=adjoint@piscine.fr
ADMIN2_PASSWORD=change-me-admin-2
ADMIN2_NOM=Adjoint
ADMIN2_PRENOM=Second

# Numéro de téléphone du directeur affiché aux intervenants (annulation).
PUBLIC_DIRECTEUR_TEL=06 00 00 00 00

# Notifications push (Web Push / VAPID). Générer avec : node scripts/generate-vapid.mjs
# PUBLIC_VAPID_KEY est exposée au client (non secrète) ; VAPID_PRIVATE_KEY reste secrète.
# Si non renseignées, l'app fonctionne mais aucune notification n'est envoyée.
# ⚠️ Déploiement docker compose : le bloc `environment:` de docker-compose.yml ne
# transmet PAS encore ces trois variables au conteneur — les y ajouter, sinon le
# push reste inactif en production (voir docs/AUDIT.md M10).
PUBLIC_VAPID_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com
